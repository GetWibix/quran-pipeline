// schema.prisma
// تتبع تقدم القراءة عبر القرآن + سجل المحتوى المنشور + بيانات التفاعل

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  SHORT
  LONG_VIDEO
}

enum PublishStatus {
  PENDING
  GENERATING
  READY
  PUBLISHED
  FAILED
}

/// كيتتبع آخر نقطة وصلنا ليها فالقراءة التسلسلية للقرآن
/// صف واحد فقط فهاد الجدول (singleton) لكل نوع محتوى (SHORT يقرا بسرعة، LONG_VIDEO يقرا أبطأ)
model ReadingProgress {
  id              Int         @id @default(autoincrement())
  contentType     ContentType @unique
  currentSurah    Int         @default(1)
  currentAyah     Int         @default(1)
  updatedAt       DateTime    @updatedAt
}

/// سجل كل فيديو تم توليده/نشره — أساس قرارات الوكيل المستقبلية
model PublishedContent {
  id                String        @id @default(cuid())
  contentType       ContentType
  surahNumber       Int
  fromAyah          Int
  toAyah            Int
  reciter           String
  videoFilePath     String?
  youtubeVideoId     String?
  title             String
  description       String
  status            PublishStatus @default(PENDING)
  scheduledAt        DateTime?
  publishedAt        DateTime?

  // بيانات التفاعل (كيتم تحديثها لاحقاً عبر job دوري يسحب من YouTube Analytics API)
  views             Int           @default(0)
  likes             Int           @default(0)
  comments          Int           @default(0)
  watchTimeMinutes  Float         @default(0)
  engagementScore   Float         @default(0) // محسوب: (likes+comments)/views * watchTime weight

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([contentType, publishedAt])
}

/// قرارات الوكيل بخصوص الجدولة — سجل تدقيق (audit log) لشفافية القرارات
model AgentDecisionLog {
  id            String   @id @default(cuid())
  decisionType  String   // "SCHEDULE_TIME" | "EXTRA_SHORT_TRIGGERED" | "RECITER_SELECTION"
  reasoning     String   // تفسير نصي بالـ LLM لشنو وعلاش اتخذ القرار
  contextData   Json?    // بيانات إضافية (مثل متوسط التفاعل آخر 7 أيام)
  createdAt     DateTime @default(now())
}

/// عداد استخدام الـ YouTube API quota اليومي — حارس قبل أي عملية رفع
model QuotaUsage {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @db.Date // يوم واحد = صف واحد (UTC، نفس توقيت يوتيوب)
  unitsUsed   Int      @default(0)
  updatedAt   DateTime @updatedAt
}
