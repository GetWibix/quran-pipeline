# --- قاعدة البيانات ---
DATABASE_URL="postgresql://user:password@localhost:5432/quran_pipeline"
POSTGRES_DB="quran_pipeline"
POSTGRES_USER="quran_user"
POSTGRES_PASSWORD="change_me_in_production"

# --- Redis (BullMQ) ---
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="change_me_in_production"

# GitHub Pages (OAuth consent screen)
# https://getwibix.github.io/quran-pipeline/
# https://getwibix.github.io/quran-pipeline/privacy.html

# --- YouTube Data API v3 (Google Cloud Console) ---
YT_CLIENT_ID="xxxxx.apps.googleusercontent.com"
YT_CLIENT_SECRET="xxxxx"
# يتم الحصول عليه مرة واحدة عبر: npx ts-node src/scripts/getRefreshToken.ts
# (يستخدم OAuth 2.0 loopback redirect — يجب أن يكون OAuth Client من نوع "Desktop Application")
YT_REFRESH_TOKEN="xxxxx"

# --- OpenRouter API (AI لتوليد العنوان/الوصف/الهاشتاغات) ---
OPENROUTER_API_KEY="sk-or-xxxxx"

# --- Telegram Bot (الإشعارات) ---
TELEGRAM_BOT_TOKEN="xxxxx:xxxxx"
TELEGRAM_CHAT_ID="xxxxx"

# ============================================================
# منصات التواصل المتعددة (Meta: Facebook + Instagram + Threads)
# ============================================================
# 1. أنشئ تطبيق في https://developers.facebook.com
# 2. أضف Facebook Login for Business + Instagram Graph API + Threads API
# 3. احصل على App ID + App Secret
# 4. صلاحيات مطلوبة:
#    - pages_manage_posts (نشر)
#    - pages_read_engagement (تحليل التفاعل)
#    - instagram_basic + instagram_manage_insights (تحليل انستغرام)
#    - instagram_content_publish (نشر انستغرام)
#    - threads_content_publish (نشر تريدز)
# 5. GET /me/accounts ← page_id
# 6. GET /{page-id}?fields=instagram_business_account ← instagram_business_account.id
# ---

# META_APP_ID="123456789"
# META_APP_SECRET="xxxxx"

# --- Facebook Page ---
# META_PAGE_ID="123456789"
# META_PAGE_ACCESS_TOKEN="EAxxxxx"

# --- Instagram Business Account ID ---
# (يشترك في نفس META_PAGE_ACCESS_TOKEN إذا كان الحساب Business ومرتبط بالصفحة)
# INSTAGRAM_BUSINESS_ID="123456789"

# --- Threads ---
# THREADS_USER_ID="123456789"
# THREADS_ACCESS_TOKEN="EAxxxxx"

# --- Cloudflare R2 (للرفع السحابي — Instagram + Threads يحتاجون رابط عام) ---
# 1. روح لـ Cloudflare Dashboard → R2 → Create Bucket
# 2. Settings → Public Access → شغّل
# 3. أنشئ API Token (R2 → Manage R2 API Tokens)
# R2_ACCOUNT_ID="your-account-id"
# R2_ACCESS_KEY="your-access-key"
# R2_SECRET_KEY="your-secret-key"
# R2_BUCKET="quran-videos"
# R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
