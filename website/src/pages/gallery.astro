---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
---

<BaseLayout title="المعرض" canonical="https://quran.waxbix.com/gallery" description="شاهد أحدث فيديوهات NOR Quran المنشورة">
  <Header />

  <section id="main-content" class="pt-32 pb-16 relative min-h-screen">
    <div class="hero-glow"></div>
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-4">
        <span class="gradient-text">المعرض</span>
      </h1>
      <p class="text-text-secondary text-center text-lg mb-12">أحدث فيديوهات NOR Quran المنشورة</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <YouTubeEmbed videoId="MedcpoVFAbI" title="فيديو 1" />
        <YouTubeEmbed videoId="nBaZ86iZJik" title="فيديو 2" />
        <YouTubeEmbed videoId="b0YYKoCr1sU" title="فيديو 3" />
        <YouTubeEmbed videoId="mHzfto1wL4Q" title="فيديو 4" />
        <YouTubeEmbed videoId="DF4d2D3PB3A" title="فيديو 5" />
        <YouTubeEmbed videoId="-W1_jS9zd8Y" title="فيديو 6" />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
