---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';

export async function getStaticPaths() {
  const res = await fetch('https://api.alquran.cloud/v1/surah');
  const data = await res.json();
  const surahs = data.data;
  return surahs.map((surah) => ({
    params: { number: String(surah.number) },
    props: { surah },
  }));
}

export interface Props {
  surah: {
    number: number;
    name: string;
    englishName: string;
    englishNameTranslation: string;
    numberOfAyahs: number;
    revelationType: string;
  };
}

const { surah } = Astro.props;
const revelationAr = surah.revelationType === 'Meccan' ? 'مكية' : 'مدنية';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'NOR Quran', item: 'https://quran.waxbix.com' },
    { '@type': 'ListItem', position: 2, name: 'القرآن الكريم', item: 'https://quran.waxbix.com/quran' },
    { '@type': 'ListItem', position: 3, name: surah.name, item: `https://quran.waxbix.com/quran/${surah.number}` },
  ],
};

const ayahsRes = await fetch(`https://api.alquran.cloud/v1/surah/${surah.number}`);
const ayahsData = await ayahsRes.json();
const ayahs = ayahsData.data.ayahs;
const ayahsJson = JSON.stringify(ayahs);
---

<BaseLayout title={surah.name} description={`سورة ${surah.name} - ${surah.numberOfAyahs} آية`} canonical={`https://quran.waxbix.com/quran/${surah.number}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <Header />

  <section class="pt-32 pb-16 relative min-h-screen">
    <div class="hero-glow"></div>
    <div class="max-w-4xl mx-auto px-4">
      <a href="/quran" class="text-primary hover:text-secondary transition-colors mb-6 inline-block">← العودة إلى السور</a>

      <div class="text-center mb-8">
        <div class="text-4xl font-bold font-amiri mb-2 gradient-text">{surah.name}</div>
        <div class="text-text-secondary">{surah.englishName} — {surah.englishNameTranslation}</div>
        <div class="text-text-muted text-sm mt-1">{revelationAr} · {surah.numberOfAyahs} آية</div>
      </div>

      <div id="ayahs-container" class="space-y-6">
        {ayahs.map((ayah) => (
          <div class="glow-card p-6 text-center" id={`ayah-${ayah.numberInSurah}`}>
            <div class="text-text-muted text-xs mb-2">الآية {ayah.numberInSurah}</div>
            <div class="arabic-verse mb-3">{ayah.text}</div>
            <button
              onclick={`playAudio(${ayah.numberInSurah})`}
              class="text-primary hover:text-secondary transition-colors text-sm"
              id={`play-btn-${ayah.numberInSurah}`}
            >
              <Icon name="play" size={14} class="inline ml-1" /> استمع
            </button>
            <audio id={`audio-${ayah.numberInSurah}`} preload="none"></audio>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  window.playAudio = function (ayahNumber) {
    const surahNumber = window.location.pathname.split('/').pop();
    const audio = document.getElementById(`audio-${ayahNumber}`);
    const btn = document.getElementById(`play-btn-${ayahNumber}`);
    const num = surahNumber.toString().padStart(3, '0');
    const a = ayahNumber.toString().padStart(3, '0');
    const url = `https://everyayah.com/data/Abdul_Basit_Murattal_64kbps/${num}${a}.mp3`;

    if (audio.src !== url) {
      audio.src = url;
    }

    if (audio.paused) {
      audio.play();
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="14" height="14" class="inline ml-1" fill="currentColor"><path d="M48 64C21.5 64 0 85.5 0 112v288c0 26.5 21.5 48 48 48h32c26.5 0 48-21.5 48-48V112c0-26.5-21.5-48-48-48H48zm192 0c-26.5 0-48 21.5-48 48v288c0 26.5 21.5 48 48 48h32c26.5 0 48-21.5 48-48V112c0-26.5-21.5-48-48-48H240z"/></svg> إيقاف';
    } else {
      audio.pause();
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="14" height="14" class="inline ml-1" fill="currentColor"><path d="M73 39c-14.8-9.3-33.4-9.1-48 .3-14.7 9.5-23.7 25.9-23.7 43.6v346.2c0 17.7 9 34.1 23.7 43.6 14.6 9.4 33.2 9.6 48 .3l288-194.3c14.4-9.7 22.3-25.1 22.3-41s-7.9-31.3-22.3-41L73 39z"/></svg> استمع';
    }

    audio.onended = () => {
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" width="14" height="14" class="inline ml-1" fill="currentColor"><path d="M73 39c-14.8-9.3-33.4-9.1-48 .3-14.7 9.5-23.7 25.9-23.7 43.6v346.2c0 17.7 9 34.1 23.7 43.6 14.6 9.4 33.2 9.6 48 .3l288-194.3c14.4-9.7 22.3-25.1 22.3-41s-7.9-31.3-22.3-41L73 39z"/></svg> استمع';
    };
  };
</script>
