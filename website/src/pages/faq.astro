---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  {
    q: 'هل الموقع مجاني؟',
    a: 'نعم، NOR Quran مفتوح المصدر ومجاني تماماً للأعمال الخيرية. لا توجد أي رسوم أو اشتراكات.',
  },
  {
    q: 'هل أستطيع استخدام الكود لمشروعي؟',
    a: 'نعم، بشرط غير تجاري. الكود مرخص للاستخدام الشخصي والخيري.',
  },
  {
    q: 'هل يحتاج سيرفر قوي؟',
    a: 'لا، 1-2GB RAM كافية لتشغيل النظام. يمكنك استخدام VPS منخفض التكلفة.',
  },
  {
    q: 'كيف أحصل على توكن يوتيوب؟',
    a: 'عبر تشغيل سكريبت getRefreshToken الموجود في المشروع. اتبع التعليمات في صفحة /docs.',
  },
  {
    q: 'هل يدعم ترجمة القرآن؟',
    a: 'حالياً النظام يدعم العربية فقط. دعم الترجمة الإنجليزية قيد التطوير.',
  },
  {
    q: 'كيف أضيف قارئ جديد؟',
    a: 'يعدل في الكود بإضافة القارئ الجديد في ملف التوزيع العشوائي وتوفير ملفات الصوت الخاصة به.',
  },
  {
    q: 'كم فيديو ينشر في اليوم؟',
    a: 'النظام يجدول النشر كل 4 ساعات بمعدل 6 فيديوهات في اليوم.',
  },
  {
    q: 'هل يمكن استخدامه تجارياً؟',
    a: 'للأعمال التجارية يرجى التواصل عبر contact@waxbix.com.',
  },
];
---

<BaseLayout title="الأسئلة الشائعة" canonical="https://quran.waxbix.com/faq" description="أجوبة على الأسئلة المتكررة حول مشروع NOR Quran">
  <Header />

  <section id="main-content" class="pt-32 pb-10 xs:pb-12 sm:pb-16 relative min-h-screen overflow-hidden">
    <div class="hero-glow"></div>
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-3xl xs:text-4xl md:text-5xl font-bold text-center mb-3 sm:mb-4">
        <span class="gradient-text">الأسئلة الشائعة</span>
      </h1>
      <p class="text-text-secondary text-center text-sm xs:text-base md:text-lg mb-8 sm:mb-12">إجابات على أكثر الأسئلة تكرراً</p>

      <div class="space-y-3 sm:space-y-4" role="list">
        {faqs.map((faq, i) => (
          <div class="glow-card p-4 xs:p-5 sm:p-6" role="listitem">
            <h3>
              <button
                class="faq-btn w-full flex items-center justify-between text-right py-2 sm:py-3 min-h-[44px] gap-2"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
                id={`faq-btn-${i}`}
              >
                <span class="font-bold text-sm xs:text-base sm:text-lg">{faq.q}</span>
                <svg class="w-5 h-5 text-text-secondary transform transition-transform duration-300 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </h3>
            <div
              id={`faq-answer-${i}`}
              role="region"
              aria-labelledby={`faq-btn-${i}`}
              class="faq-answer hidden mt-4 text-text-secondary leading-relaxed"
            >
              {faq.a}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach((btn) => {
    const answer = btn.nextElementSibling;
    const icon = btn.querySelector('svg');

    function open() {
      answer.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      icon.classList.add('rotate-180');
    }

    function close() {
      answer.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      icon.classList.remove('rotate-180');
    }

    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    });

    btn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        isOpen ? close() : open();
      }
    });
  });
</script>
