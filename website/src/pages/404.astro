---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="الصفحة غير موجودة" canonical="https://quran.waxbix.com/404">
  <div class="min-h-screen flex items-center justify-center bg-bg-dark relative overflow-hidden">
    <div class="hero-glow"></div>
    <div class="text-center z-10 px-4">
      <div class="text-9xl font-bold gradient-text mb-4">404</div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">الصفحة غير موجودة</h1>
      <p class="text-text-secondary text-lg mb-8">عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها</p>
      <a href="/" class="btn-primary text-lg px-8 py-4">العودة إلى الرئيسية</a>
    </div>
  </div>
</BaseLayout>
