---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const res = await fetch('https://api.alquran.cloud/v1/surah');
const data = await res.json();
const surahs = data.data;
const surahsJson = JSON.stringify(surahs);
---

<BaseLayout title="القرآن الكريم" canonical="https://quran.waxbix.com/quran" description="استمع إلى القرآن الكريم بصوت الشيخ عبد الباسط">
  <Header />

  <section id="main-content" class="min-h-screen">
    <div class="bg-gradient-to-b from-accent/20 via-accent/5 to-bg-dark pt-16 md:pt-20 pb-8">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-end gap-6 mb-8">
          <div class="w-32 h-32 md:w-48 md:h-48 rounded-2xl shadow-2xl bg-gradient-to-br from-accent to-emerald-600 flex items-center justify-center flex-shrink-0 -mt-4">
            <span class="text-6xl md:text-7xl font-bold text-white font-amiri">ق</span>
          </div>
          <div class="flex-1 min-w-0 pb-1">
            <p class="text-xs md:text-sm text-text-muted uppercase tracking-wider mb-1">القرآن الكريم</p>
            <h1 class="text-3xl md:text-6xl font-bold text-white truncate">القرآن الكريم</h1>
            <p class="text-sm md:text-base text-text-secondary mt-1 truncate">استمع بأصوات أشهر القراء · 114 سورة</p>
            <div class="flex items-center gap-2 mt-2">
              <a href="#download-mushaf" class="text-xs text-text-muted hover:text-accent transition-colors">اختر القارئ من صفحة السورة · تحميل المصحف</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 -mt-2">
      <div class="flex flex-col sm:flex-row gap-3 mb-6">
        <div class="flex-1">
          <label for="search-input" class="sr-only">ابحث عن سورة</label>
          <div class="relative">
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="search-input"
              placeholder="ابحث باسم أو رقم السورة..."
              class="w-full px-10 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder-text-muted focus:outline-none focus:border-accent transition-colors min-h-[44px]"
              autocomplete="off"
            />
          </div>
        </div>
        <div class="flex gap-2 overflow-x-auto" id="filter-btns">
          <button data-filter="all" class="filter-btn px-4 py-2.5 rounded-full text-sm font-medium transition-all bg-white text-black min-h-[44px] whitespace-nowrap">الكل</button>
          <button data-filter="Meccan" class="filter-btn px-4 py-2.5 rounded-full text-sm font-medium transition-all bg-white/10 text-text-secondary hover:bg-white/20 min-h-[44px] whitespace-nowrap">مكية</button>
          <button data-filter="Medinan" class="filter-btn px-4 py-2.5 rounded-full text-sm font-medium transition-all bg-white/10 text-text-secondary hover:bg-white/20 min-h-[44px] whitespace-nowrap">مدنية</button>
        </div>
      </div>

      <a id="download-mushaf" href="https://dm.qurancomplex.gov.sa/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mb-6 px-4 py-2.5 rounded-lg bg-accent/10 text-accent hover:bg-accent/20 transition-colors text-sm min-h-[44px]">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        تحميل المصحف الشريف (PDF - مجمع الملك فهد)
      </a>

      <div id="surahs-container" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 pb-8">
        {surahs.map((s) => (
          <a href={`/quran/${s.number}`} class="group bg-card hover:bg-card-hover rounded-xl p-4 transition-all duration-300">
            <div class="relative w-full aspect-square mb-3 rounded-lg bg-gradient-to-br from-accent/30 to-accent/10 overflow-hidden shadow-lg group-hover:shadow-xl group-hover:shadow-accent/10 transition-all">
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-3xl md:text-4xl font-bold text-white/80 font-amiri">{s.number}</span>
              </div>
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-accent shadow-xl shadow-accent/30 flex items-center justify-center opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all">
                  <svg class="w-5 h-5 mr-0.5 text-white" fill="currentColor" viewBox="0 0 384 512">
                    <path d="M73 39c-14.8-9.3-33.4-9.1-48 .3-14.7 9.5-23.7 25.9-23.7 43.6v346.2c0 17.7 9 34.1 23.7 43.6 14.6 9.4 33.2 9.6 48 .3l288-194.3c14.4-9.7 22.3-25.1 22.3-41s-7.9-31.3-22.3-41L73 39z"/>
                  </svg>
                </div>
              </div>
            </div>
            <div class="text-sm font-semibold truncate text-white">{s.name}</div>
            <div class="text-xs text-text-muted truncate mt-0.5">{s.englishName}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script id="surahs-data" type="application/json" set:html={surahsJson}></script>

<script>
  const surahs = JSON.parse(document.getElementById('surahs-data').textContent);
  const container = document.getElementById('surahs-container');
  const searchInput = document.getElementById('search-input');
  const filterBtns = document.querySelectorAll('.filter-btn');
  let activeFilter = 'all';

  function renderSurahs() {
    const query = (searchInput?.value || '').trim();
    const filtered = surahs.filter((s) => {
      const matchesSearch = !query
        || s.name.includes(query)
        || s.englishName.toLowerCase().includes(query.toLowerCase())
        || String(s.number) === query;
      const matchesFilter = activeFilter === 'all' || s.revelationType === activeFilter;
      return matchesSearch && matchesFilter;
    });

    if (filtered.length === 0) {
      container.innerHTML = '<div class="col-span-full text-center text-text-muted py-16">لا توجد نتائج للبحث</div>';
      return;
    }

    container.innerHTML = filtered
      .map((s) => `
        <a href="/quran/${s.number}" class="group bg-card hover:bg-card-hover rounded-xl p-4 transition-all duration-300">
          <div class="relative w-full aspect-square mb-3 rounded-lg bg-gradient-to-br from-accent/30 to-accent/10 overflow-hidden shadow-lg group-hover:shadow-xl group-hover:shadow-accent/10 transition-all">
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-3xl md:text-4xl font-bold text-white/80 font-amiri">${s.number}</span>
            </div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center">
              <div class="w-12 h-12 rounded-full bg-accent shadow-xl shadow-accent/30 flex items-center justify-center opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all">
                <svg class="w-5 h-5 mr-0.5 text-white" fill="currentColor" viewBox="0 0 384 512">
                  <path d="M73 39c-14.8-9.3-33.4-9.1-48 .3-14.7 9.5-23.7 25.9-23.7 43.6v346.2c0 17.7 9 34.1 23.7 43.6 14.6 9.4 33.2 9.6 48 .3l288-194.3c14.4-9.7 22.3-25.1 22.3-41s-7.9-31.3-22.3-41L73 39z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="text-sm font-semibold truncate text-white">${s.name}</div>
          <div class="text-xs text-text-muted truncate mt-0.5">${s.englishName}</div>
        </a>
      `).join('');
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('bg-white', 'text-black');
        b.classList.add('bg-white/10', 'text-text-secondary');
      });
      btn.classList.remove('bg-white/10', 'text-text-secondary');
      btn.classList.add('bg-white', 'text-black');
      activeFilter = btn.getAttribute('data-filter');
      renderSurahs();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', renderSurahs);
  }
</script>
