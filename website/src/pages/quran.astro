---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const res = await fetch('https://api.alquran.cloud/v1/surah');
const data = await res.json();
const surahs = data.data;
const surahsJson = JSON.stringify(surahs);
---

<BaseLayout title="القرآن الكريم" canonical="https://quran.waxbix.com/quran" description="اقرأ القرآن الكريم واستمع إلى آياته">
  <Header />

  <section id="main-content" class="pt-20 md:pt-24 pb-16 min-h-screen">
    <div class="max-w-7xl mx-auto px-4">

      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-8 bg-accent rounded-full"></div>
        <h1 class="text-3xl font-bold">القرآن الكريم</h1>
        <span class="text-text-muted text-sm mt-1">{surahs.length} سورة</span>
      </div>

      <div class="flex flex-col md:flex-row gap-4 mb-8">
        <div class="flex-1">
          <label for="search-input" class="sr-only">ابحث عن سورة</label>
          <div class="relative">
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="search-input"
              placeholder="ابحث عن سورة..."
              class="w-full px-12 py-3 bg-card border border-border rounded-xl text-white placeholder-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all"
              autocomplete="off"
            />
          </div>
        </div>
        <div class="flex gap-2" id="filter-btns">
          <button data-filter="all" class="filter-btn px-5 py-3 rounded-xl text-sm font-medium transition-all bg-accent text-white">الكل</button>
          <button data-filter="Meccan" class="filter-btn px-5 py-3 rounded-xl text-sm font-medium transition-all bg-card text-text-secondary hover:bg-card-hover">مكية</button>
          <button data-filter="Medinan" class="filter-btn px-5 py-3 rounded-xl text-sm font-medium transition-all bg-card text-text-secondary hover:bg-card-hover">مدنية</button>
        </div>
      </div>

      <div id="surahs-container" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
        {surahs.map((s) => (
          <a href={`/quran/${s.number}`} class="surah-card group relative bg-card hover:bg-card-hover border border-border rounded-xl p-4 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5">
            <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
              <span class="text-accent font-bold text-sm">{s.number}</span>
            </div>
            <div class="font-semibold text-base font-amiri leading-tight mb-1">{s.name}</div>
            <div class="text-text-muted text-xs truncate">{s.englishName}</div>
            <div class="text-text-muted text-xs mt-1">{s.numberOfAyahs} آية · {s.revelationType === 'Meccan' ? 'مكية' : 'مدنية'}</div>
            <div class="absolute inset-0 rounded-xl ring-1 ring-inset ring-transparent group-hover:ring-accent/20 transition-all pointer-events-none"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script id="surahs-data" type="application/json" set:html={surahsJson}></script>

<script>
  const surahs = JSON.parse(document.getElementById('surahs-data').textContent);
  const container = document.getElementById('surahs-container');
  const searchInput = document.getElementById('search-input');
  const filterBtns = document.querySelectorAll('.filter-btn');
  let activeFilter = 'all';

  function renderSurahs() {
    const query = (searchInput?.value || '').trim();
    const filtered = surahs.filter((s) => {
      const matchesSearch = !query
        || s.name.includes(query)
        || s.englishName.toLowerCase().includes(query.toLowerCase());
      const matchesFilter = activeFilter === 'all' || s.revelationType === activeFilter;
      return matchesSearch && matchesFilter;
    });

    if (filtered.length === 0) {
      container.innerHTML = '<div class="col-span-full text-center text-text-muted py-16">لا توجد نتائج للبحث</div>';
      return;
    }

    container.innerHTML = filtered
      .map(
        (s) => `
        <a href="/quran/${s.number}" class="surah-card group relative bg-card hover:bg-card-hover border border-border rounded-xl p-4 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5">
          <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent/10 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <span class="text-accent font-bold text-sm">${s.number}</span>
          </div>
          <div class="font-semibold text-base font-amiri leading-tight mb-1">${s.name}</div>
          <div class="text-text-muted text-xs truncate">${s.englishName}</div>
          <div class="text-text-muted text-xs mt-1">${s.numberOfAyahs} آية · ${s.revelationType === 'Meccan' ? 'مكية' : 'مدنية'}</div>
          <div class="absolute inset-0 rounded-xl ring-1 ring-inset ring-transparent group-hover:ring-accent/20 transition-all pointer-events-none"></div>
        </a>
      `
      )
      .join('');
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('bg-accent', 'text-white');
        b.classList.add('bg-card', 'text-text-secondary');
      });
      btn.classList.remove('bg-card', 'text-text-secondary');
      btn.classList.add('bg-accent', 'text-white');
      activeFilter = btn.getAttribute('data-filter');
      renderSurahs();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', renderSurahs);
  }
</script>
