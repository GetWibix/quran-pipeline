---
import Icon from './Icon.astro';

export interface Props {
  icon: string;
  title: string;
  description: string;
  link?: string;
}

const { icon, title, description, link } = Astro.props;
---

<div class="glow-card p-6 group">
  <div class="mb-3"><Icon name={icon} size={28} class="text-primary" /></div>
  <h3 class="text-xl font-bold mb-2">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed mb-4">{description}</p>
  {
    link && (
      <a href={link} class="text-primary text-sm font-semibold hover:text-secondary transition-colors inline-flex items-center gap-1">
        اعرف المزيد
        <span aria-hidden="true">←</span>
      </a>
    )
  }
</div>
